# App
NODE_ENV=development
PORT=3000
APP_NAME=RentDecla API

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=2201
DB_DATABASE=sql_curso

# JWT
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
